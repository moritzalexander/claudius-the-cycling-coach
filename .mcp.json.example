{
  "mcpServers": {
    "intervals-icu": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "<PATH_TO>/intervals-icu-mcp",
        "intervals-icu-mcp"
      ],
      "env": {
        "INTERVALS_ICU_API_KEY": "<YOUR_API_KEY>",
        "INTERVALS_ICU_ATHLETE_ID": "<YOUR_ATHLETE_ID>"
      }
    }
  }
}
